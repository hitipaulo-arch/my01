# Exemplo de arquivo .env — NÃO COMITAR suas chaves reais.
# Copie este arquivo para `.env` e preencha os valores reais localmente.

SECRET_KEY=SUBSTITUA_POR_UMA_CHAVE_SECRETA_GENERADA

# Google Sheets Configuration
GOOGLE_SHEET_ID=1qs3cxlklTnzCp4RpQGhxIrEF4CbeUvid1S0Cp2tC3Xg
GOOGLE_SHEET_TAB=Respostas ao formulário 3
GOOGLE_SHEET_HORARIO_TAB=Controle de Horário
GOOGLE_SHEET_USUARIOS_TAB=Usuários

# Flask Configuration
FLASK_DEBUG=false

# Cache Configuration (em segundos)
CACHE_TTL_SECONDS=300
CACHE_TYPE=SimpleCache

# Port (Render configura automaticamente)
PORT=5000

# ========================================
# NOTIFICAÇÕES (OPCIONAIS)
# ========================================

# --- E-mail (SMTP) ---
# Ativa notificação por e-mail ao abrir OS
NOTIFY_ENABLED=false
NOTIFY_TO=seuemail@gmail.com,outro@empresa.com
NOTIFY_FROM=seuemail@gmail.com

# Configuração Gmail (exemplo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=sua_senha_de_app_aqui
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10

# --- WhatsApp (Click-to-Chat e Webhook) ---
# Ativa notificação por WhatsApp ao abrir OS (sem Twilio)
WHATSAPP_ENABLED=false

# Webhook para receber mensagens via WhatsApp
# Permite técnicos enviar status/comandos via WhatsApp
WHATSAPP_WEBHOOK_ENABLED=false
WHATSAPP_WEBHOOK_TOKEN=seu_token_seguro_aqui
WHATSAPP_WEBHOOK_FROM=5512982200009  # Número autorizado a enviar comandos
